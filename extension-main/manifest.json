{
  "manifest_version": 3,
  "name": "Scaler++",
  "version": "1.9.20",
  "description": "Bypass companion-mode on campus WiFi, spotlight search, download lecture recordings & declutter Scaler dashboard",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "webRequest",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.google.com/*",
    "*://scaler.com/*",
    "*://*.scaler.com/*",
    "https://www.googleapis.com/calendar/*",
    "https://scalerbackend.vercel.app/*"
  ],
  "oauth2": {
    "client_id": "240142215084-so5ckgh5al2d6aipa0fg9bsokt2gdp61.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events"
    ]
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Scaler++ Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.scaler.com/*",
        "https://scaler.com/*"
      ],
      "js": [
        "content/cleaner/selectors.js",
        "content/core/settings.js",
        "content/core/styleInjector.js",
        "content/utils/domUtils.js",
        "content/utils/stringUtils.js",
        "content/features/leetcodeLink.js",
        "content/cleaner/cleanerEngine.js",
        "content/cleaner/modalHandler.js",
        "content/cleaner/sidebarHandler.js",
        "content/core/urlObserver.js",
        "content/features/problemSearch.js",
        "content/features/practiceMode.js",
        "content/features/joinClassButton.js",
        "content/features/subjectSort.js",
        "content/features/contestLeaderboard.js",
        "content/features/videoDownloader/videoDownloader.js",
        "content/features/customMessage.js",
        "content/features/problemPicker.js",
        "content/features/usernameTracker.js",
        "content/features/lectureInfo.js",
        "content/features/instructorInfo.js",
        "content/features/spotlightSearch.js",
        "content/features/liveStreamRecorder/liveStreamRecorder.js",
        "content/content.js"
      ],
      "css": [
        "content/features/liveStreamRecorder/liveStreamRecorder.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/leetcode_icon.png",
        "libs/agora-sdk.js",
        "content/features/liveStreamRecorder/recorderBridge.js"
      ],
      "matches": [
        "https://www.scaler.com/*",
        "https://scaler.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}